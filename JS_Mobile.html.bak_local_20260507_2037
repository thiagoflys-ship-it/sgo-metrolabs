      ${exigeFoto ? `
        <div style="margin-top:10px;">
          <label class="mobile-btn-secondary" style="width:100%;display:flex;justify-content:center;align-items:center;cursor:pointer;">
            <i class="fas fa-camera" style="margin-right:8px;"></i>Adicionar foto
            <input type="file" accept="image/*" capture="environment" style="display:none;" onchange="mobileExecFotoQuestao_(this,'${pid}')">
          </label>
          <input type="hidden" class="m-exec-check-foto" value="${escapeHtml_(foto)}">
          <div id="mExecFotoStatus_${pid}" style="font-size:12px;font-weight:700;margin-top:7px;color:${foto ? '#059669' : 'var(--muted)'};">${foto ? 'Foto anexada' : 'Nenhuma foto anexada'}</div>
