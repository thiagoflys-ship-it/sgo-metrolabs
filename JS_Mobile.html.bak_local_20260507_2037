<script>
/* ================================================================
 * JS_Mobile.html — SGO+ Campo
 * Interface mobile própria para operação em campo
 * Dependência: escapeHtml_() definida em JS_Core.html
 * ================================================================ */

var MOBILE_TELA_ATUAL = "home";

/* ---- Estado: Nova OS ---- */
var MOBILE_OS_OPCOES       = null;
var MOBILE_OS_QUESTIONARIO = null;
var MOBILE_OS_PREFILL      = null;

/* ---- Estado: Minhas OS ---- */
var MOBILE_MINHAS_OS_DADOS  = [];
var MOBILE_MINHAS_OS_FILTRO = "todas";

/* ---- Estado: Execucao mobile ---- */
var MOBILE_EXEC_STATE = {
  osId: null,
  os: null,
  checklistModelo: null,
  checklist: [],
  fotosFila: [],
  respostas: {},
  assinaturas: []
};

/* ---- Detecção ---- */

function isMobile_() {
  if (window.innerWidth <= 900) return true;
  try {
    return /Android|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent || "");
  } catch(e) { return false; }
}

function mobileDeveAtivar_() {
  try { return isMobile_(); } catch(e) { return false; }
}

/* ---- Entry point ---- */

function renderMobileCampo_() {
  var topbar  = document.querySelector(".topbar");
  var sidebar = document.querySelector(".sidebar");
  if (topbar)  topbar.style.display  = "none";
  if (sidebar) sidebar.style.display = "none";

  var div = document.getElementById("conteudo");
  if (!div) return;
  
  div.innerHTML = `
    <div class="mobile-shell" id="mobileCampoShell">
      <div class="mobile-top">
        <div class="mobile-top-brand">
          <span class="mobile-top-title">SGO+ Campo</span>
          <span class="mobile-top-sub">Operação em campo</span>
        </div>
        <button class="mobile-top-exit" type="button" onclick="mobileModoGestaoCompleto_()">&#8921; Gestão</button>
      </div>
      <div id="mobilePaneContainer" class="mobile-pane-container"></div>
      <nav class="mobile-bottom-nav" id="mobileBottomNav">
        <button class="mobile-nav-btn" id="mobileNavInicio" type="button" onclick="mobileAbrirTela_('home')">
          <i class="fas fa-house mobile-nav-icon"></i>
          <span class="mobile-nav-label">Início</span>
        </button>
        <button class="mobile-nav-btn" id="mobileNavOS" type="button" onclick="mobileAbrirTela_('minhas_os')">
          <i class="fas fa-clipboard-list mobile-nav-icon"></i>
          <span class="mobile-nav-label">Minhas OS</span>
        </button>
        <button class="mobile-nav-btn" id="mobileNavFrota" type="button" onclick="mobileAbrirTela_('frota')">
          <i class="fas fa-car-side mobile-nav-icon"></i>
          <span class="mobile-nav-label">Frota</span>
        </button>
        <button class="mobile-nav-btn" id="mobileNavQR" type="button" onclick="mobileAbrirTela_('qr')">
          <i class="fas fa-qrcode mobile-nav-icon"></i>
          <span class="mobile-nav-label">QR</span>
        </button>
        <button class="mobile-nav-btn" id="mobileNavMenu" type="button" onclick="mobileAbrirTela_('menu')">
          <i class="fas fa-bars mobile-nav-icon"></i>
          <span class="mobile-nav-label">Menu</span>
        </button>
      </nav>
    </div>
  `;
  mobileAbrirTela_("home");
}

/* ---- Navegação interna ---- */

function mobileAbrirTela_(nome) {
  MOBILE_TELA_ATUAL = nome;

  var container = document.getElementById("mobilePaneContainer");
  if (!container) return;
  
  var navMap = {
    home:     "mobileNavInicio",
    minhas_os:"mobileNavOS",
    frota:    "mobileNavFrota",
    qr:       "mobileNavQR",
    menu:     "mobileNavMenu"
  };
  
  Object.keys(navMap).forEach(function(k) {
    var btn = document.getElementById(navMap[k]);
    if (btn) btn.classList.toggle("mobile-nav-ativo", k === nome);
  });
  
  switch (nome) {
    case "home":
      container.innerHTML = mobileHtmlHome_();
      break;
    case "minhas_os":
      MOBILE_MINHAS_OS_DADOS  = [];
      MOBILE_MINHAS_OS_FILTRO = "todas";
      container.innerHTML = mobileHtmlMinhasOS_();
      mobileCarregarMinhasOS_();
      break;
    case "frota":
      container.innerHTML = mobileHtmlPlaceholder_(
        "Frota",
        "fas fa-car-side",
        "Em breve: retirada, devolucao e abastecimento de veiculos sera implementada no Bloco 5-E."
      );
      break;
    case "qr":
      container.innerHTML = mobileHtmlPlaceholder_(
        "Ler QR",
        "fas fa-qrcode",
        "Em breve: leitura de QR Code de equipamentos sera implementada no Bloco 5-F."
      );
      break;
    case "menu":
      container.innerHTML = mobileHtmlMenu_();
      break;
    case "cliente":
      container.innerHTML = mobileHtmlClienteForm_();
      break;
    case "unidade":
      container.innerHTML = mobileHtmlUnidadeForm_();
      mobileCarregarClientesSelect_("mUnidadeClienteId");
      break;
    case "equipamento":
      MOBILE_EQUIP_FOTOS = { plaqueta: null, equipamento: null };
      container.innerHTML = mobileHtmlEquipamentoForm_();
      mobileCarregarClientesEquip_("mEquipClienteId");
      break;
    case "nova_os":
      MOBILE_OS_OPCOES       = null;
      MOBILE_OS_QUESTIONARIO = null;
      container.innerHTML = mobileHtmlNovaOS_();
      mobileCarregarOpcoesOS_();
      break;
    case "documentos":
      container.innerHTML = mobileHtmlPlaceholder_(
        "Documentos",
        "fas fa-folder-open",
        "Em breve: acesso a documentos técnicos será implementado no Bloco 5-F."
      );
      break;
    default:
      container.innerHTML = mobileHtmlPlaceholder_(nome, "fas fa-clock", "Em desenvolvimento.");
  }

  container.scrollTop = 0;
}

function mobileVoltar_() {
  mobileAbrirTela_("home");
}

/* ---- Pane: Home ---- */

function mobileHtmlHome_() {
  var nome = "Tecnico";
  if (USER_CONTEXT) {
    var n = USER_CONTEXT.nome || USER_CONTEXT.usuario || "";
    if (n) nome = n.split(" ")[0];
  }

  var cards = [
    { tela: "cliente",     icone: "fas fa-building",       label: "+ Cliente",  cor: "#dbeafe" },
    { tela: "unidade",     icone: "fas fa-location-dot",   label: "+ Unidade",  cor: "#dcfce7" },
    { tela: "equipamento", icone: "fas fa-microscope",     label: "+ Equip.",   cor: "#fef3c7" },
    { tela: "nova_os",     icone: "fas fa-plus-circle",    label: "Nova OS",    cor: "#ede9fe" },
    { tela: "minhas_os",   icone: "fas fa-clipboard-list", label: "Minhas OS",  cor: "#e0f2fe" },
    { tela: "frota",       icone: "fas fa-car-side",       label: "Frota",      cor: "#d1fae5" },
    { tela: "qr",          icone: "fas fa-qrcode",         label: "Ler QR",     cor: "#e0e7ff" },
    { tela: "documentos",  icone: "fas fa-folder-open",    label: "Documentos", cor: "#fce7f3" }
  ];

  return `
    <div class="mobile-home">
      <p class="mobile-saudacao">Olá, ${escapeHtml_(nome)}!</p>
      <p class="mobile-saudacao-sub">Selecione uma ação</p>
      <div class="mobile-grid">
        ${cards.map(function(c) {
          return `
            <button class="mobile-card" type="button" style="background:${c.cor};" onclick="mobileAbrirTela_('${c.tela}')">
              <i class="${c.icone} mobile-card-icon"></i>
              <span class="mobile-card-label">${escapeHtml_(c.label)}</span>
            </button>
          `;
        }).join("")}
      </div>
    </div>
  `;
}

/* ---- Pane: Minhas OS ---- */

function mobileHtmlMinhasOS_() {
  var filtros = [
    { id: "todas",       label: "Todas"       },
    { id: "hoje",        label: "Hoje"        },
    { id: "abertas",     label: "Abertas"     },
    { id: "em_execucao", label: "Em execução" },
    { id: "concluidas",  label: "Concluídas"  }
  ];
  
  return `
    <div class="mobile-pane" style="padding-bottom:0;">
      <button class="mobile-back" type="button" onclick="mobileVoltar_()">
        <i class="fas fa-arrow-left"></i> Voltar
      </button>
      <h2 class="mobile-pane-title" style="padding:0 0 4px;">Minhas OS</h2>
      <div class="mobile-os-filtros" id="mOSFiltros">
        ${filtros.map(function(f) {
          return `<button class="mobile-os-filtro-btn${f.id === "todas" ? " mobile-os-filtro-ativo" : ""}" type="button" onclick="mobileOSFiltrar_('${f.id}')">${f.label}</button>`;
        }).join("")}
      </div>
      <div id="mOSListaWrap" style="padding-top:4px;">
        <div style="text-align:center;padding:48px 0;">
          <i class="fas fa-spinner fa-spin" style="font-size:28px;color:var(--metro-green);"></i>
          <div style="margin-top:12px;color:var(--muted);font-size:13px;">Carregando...</div>
        </div>
      </div>
    </div>
  `;
}

function mobileCarregarMinhasOS_() {
  google.script.run
    .withSuccessHandler(function(res) {
      console.log("[mobile] osListar:", res && res.total, "itens");
      if (!res || !res.success) {
        mobileOSRenderErroLista_((res && res.message) || "Erro ao carregar OS.");
        return;
      }
      MOBILE_MINHAS_OS_DADOS = res.items || [];
      mobileOSRenderCards_(MOBILE_MINHAS_OS_FILTRO);
    })
    .withFailureHandler(function(err) {
      console.error("[mobile] osListar failure:", err);
      mobileOSRenderErroLista_("Erro ao carregar: " + (err.message || String(err)));
    })
    .osListar(SESSION);
}

function mobileOSRenderErroLista_(msg) {
  var wrap = document.getElementById("mOSListaWrap");
  if (!wrap) return;
  
  wrap.innerHTML = `
    <div class="mobile-placeholder-box" style="background:#fef2f2;border-color:#fca5a5;margin:16px;">
      <i class="fas fa-circle-exclamation" style="font-size:32px;color:#ef4444;display:block;margin-bottom:10px;"></i>
      <div style="font-size:13px;color:#b91c1c;">${escapeHtml_(msg)}</div>
      <button class="mobile-btn-secondary" type="button" onclick="mobileCarregarMinhasOS_()" style="margin-top:14px;">Tentar novamente</button>
    </div>
  `;
}

function mobileOSFiltrar_(filtro) {
  MOBILE_MINHAS_OS_FILTRO = filtro;
  var btns = document.querySelectorAll(".mobile-os-filtro-btn");
  var ids  = ["todas","hoje","abertas","em_execucao","concluidas"];
  
  btns.forEach(function(b, i) {
    b.classList.toggle("mobile-os-filtro-ativo", ids[i] === filtro);
  });
  mobileOSRenderCards_(filtro);
}

function mobileOSRenderCards_(filtro) {
  var wrap = document.getElementById("mOSListaWrap");
  if (!wrap) return;

  var itens = MOBILE_MINHAS_OS_DADOS;
  var hoje  = new Date().toISOString().substring(0, 10);

  if (filtro === "hoje") {
    itens = itens.filter(function(o) {
      return (o.DATA_AGENDADA && String(o.DATA_AGENDADA).substring(0,10) === hoje) ||
             (o.DATA_ABERTURA && String(o.DATA_ABERTURA).substring(0,10) === hoje);
    });
  } else if (filtro === "abertas") {
    itens = itens.filter(function(o) {
      var s = String(o.STATUS || "").toUpperCase();
      return s === "ABERTA" || s === "AGENDADA";
    });
  } else if (filtro === "em_execucao") {
    itens = itens.filter(function(o) {
      return String(o.STATUS || "").toUpperCase() === "EM_EXECUCAO";
    });
  } else if (filtro === "concluidas") {
    itens = itens.filter(function(o) {
      var s = String(o.STATUS || "").toUpperCase();
      return ["CONCLUIDA","CONCLUIDA_TECNICAMENTE","APROVADA","FATURADA"].indexOf(s) >= 0;
    });
  }

  if (!itens.length) {
    wrap.innerHTML = `
      <div class="mobile-placeholder-box" style="background:#f0f9ff;border-color:#bae6fd;margin:16px;">
        <i class="fas fa-clipboard-list" style="font-size:36px;color:#0ea5e9;display:block;margin-bottom:10px;"></i>
        <div style="font-size:13px;color:#0369a1;">Nenhuma OS encontrada para este filtro.</div>
      </div>
    `;
    return;
  }

  wrap.innerHTML = `
    <div class="mobile-os-lista">
      ${itens.map(function(o) { return mobileOSRenderCard_(o); }).join("")}
    </div>
  `;
}

function mobileOSBadgeStatus_(status) {
  var s = String(status || "").toUpperCase();
  var cor = "#6b7280", bg = "#f3f4f6";
  
  if (s === "ABERTA") { cor = "#1d4ed8"; bg = "#dbeafe"; }
  else if (s === "AGENDADA") { cor = "#7c3aed"; bg = "#ede9fe"; }
  else if (s === "EM_EXECUCAO") { cor = "#059669"; bg = "#d1fae5"; }
  else if (s === "CONCLUIDA" || s === "CONCLUIDA_TECNICAMENTE") { cor = "#065f46"; bg = "#d1fae5"; }
  else if (s === "APROVADA") { cor = "#065f46"; bg = "#bbf7d0"; }
  else if (s === "CANCELADA") { cor = "#991b1b"; bg = "#fee2e2"; }
  
  return `<span style="display:inline-block;padding:2px 8px;border-radius:12px;font-size:11px;font-weight:700;background:${bg};color:${cor};">${escapeHtml_(s.replace(/_/g," "))}</span>`;
}

function mobileOSBadgePrioridade_(prioridade) {
  var p = String(prioridade || "").toUpperCase();
  var cor = "#6b7280", bg = "#f3f4f6";
  
  if (p === "URGENTE") { cor = "#991b1b"; bg = "#fee2e2"; }
  else if (p === "ALTA") { cor = "#c2410c"; bg = "#ffedd5"; }
  else if (p === "NORMAL") { cor = "#1d4ed8"; bg = "#dbeafe"; }
  
  return `<span style="display:inline-block;padding:2px 8px;border-radius:12px;font-size:11px;font-weight:700;background:${bg};color:${cor};">${escapeHtml_(p || "NORMAL")}</span>`;
}

function mobileOSRenderCard_(o) {
  var osId    = String(o.ID || "");
  var numero  = escapeHtml_(o.NUMERO_OS || o.ID || "OS");
  var cliente = escapeHtml_(o.CLIENTE_NOME || o.CLIENTE_ID || "");
  var unidade = escapeHtml_(o.UNIDADE_NOME || o.UNIDADE_ID || "");
  var equip   = escapeHtml_([o.EQUIPAMENTO_TAG, o.EQUIPAMENTO_TIPO].filter(Boolean).join(" / ") || o.EQUIPAMENTO_ID || "");
  var tipo    = escapeHtml_(String(o.TIPO_OS || "").replace(/_/g," "));
  var dataAgd = o.DATA_AGENDADA ? String(o.DATA_AGENDADA).substring(0,16).replace("T"," ") : "";
  var temQuest = !!(o.QUESTIONARIO_MODELO_ID);

  return `
    <div class="mobile-os-card">
      <div class="mobile-os-card-header">
        <span class="mobile-os-numero">${numero}</span>
        <div style="display:flex;gap:5px;flex-wrap:wrap;">
          ${mobileOSBadgeStatus_(o.STATUS)} ${mobileOSBadgePrioridade_(o.PRIORIDADE)}
        </div>
      </div>
      <div class="mobile-os-card-body">
        ${cliente ? `<div class="mobile-os-row"><i class="fas fa-building"></i>${cliente}</div>` : ''}
        ${unidade ? `<div class="mobile-os-row"><i class="fas fa-location-dot"></i>${unidade}</div>` : ''}
        ${equip ? `<div class="mobile-os-row"><i class="fas fa-microscope"></i>${equip}</div>` : ''}
        ${tipo ? `<div class="mobile-os-row"><i class="fas fa-tag"></i>${tipo}</div>` : ''}
        ${dataAgd ? `<div class="mobile-os-row"><i class="fas fa-calendar"></i>${escapeHtml_(dataAgd)}</div>` : ''}
        ${temQuest ? `<div class="mobile-os-row" style="color:#15803d;"><i class="fas fa-list-check" style="color:#16a34a;"></i>Questionário vinculado</div>` : ''}
      </div>
      <div class="mobile-os-card-footer">
        <button class="mobile-btn-secondary" type="button" style="flex:1;" onclick="mobileOSExecutar_('${osId}')">
          <i class="fas fa-eye" style="margin-right:6px;"></i>Abrir
        </button>
        <button class="mobile-btn-primary" type="button" style="flex:1;" onclick="mobileOSExecutar_('${osId}')">
          <i class="fas fa-play" style="margin-right:6px;"></i>Executar
        </button>
      </div>
    </div>
  `;
}

function mobileOSExecutar_(osId) {
  console.log("[OS_EXEC] mobileOSExecutar_", osId);
  var dlg = document.getElementById("mOSDialogPos");
  if (dlg) dlg.remove();
  
  if (!osId) {
    mobileToast_("ID da OS não localizado. Atualize a lista e tente novamente.", "erro");
    return;
  }

  mobileRenderExecucaoOS_(osId);
}

/* ---- Execucao mobile nativa ---- */

function mobileRenderExecucaoOS_(osId) {
  MOBILE_TELA_ATUAL = "execucao_os";
  MOBILE_EXEC_STATE = {
    osId: osId,
    os: null,
    checklistModelo: null,
    checklist: [],
    fotosFila: [],
    respostas: {},
    assinaturas: []
  };
  
  var container = document.getElementById("mobilePaneContainer");
  if (!container) return;
  
  container.innerHTML = `
    <div class="mobile-pane" style="padding:12px 12px 88px;">
      <button class="mobile-back" type="button" onclick="mobileAbrirTela_('minhas_os')">
        <i class="fas fa-arrow-left"></i> Minhas OS
      </button>
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:10px;">
        <div>
          <h2 class="mobile-pane-title" id="mExecTitulo" style="padding:0;margin:0;">Execução de OS</h2>
          <p class="mobile-pane-sub" id="mExecSub" style="margin:4px 0 0;">Carregando...</p>
        </div>
        <span id="mExecStatusBadge" style="display:inline-flex;border-radius:999px;background:#eef2ff;color:#3730a3;font-size:11px;font-weight:800;padding:5px 9px;white-space:nowrap;">OS</span>
      </div>
      <div id="mExecSteps" style="display:grid;grid-template-columns:repeat(6,1fr);gap:5px;margin:12px 0 14px;">
        ${mobileExecStepBtnHtml_(1, "Resumo")}
        ${mobileExecStepBtnHtml_(2, "Check")}
        ${mobileExecStepBtnHtml_(3, "Fotos")}
        ${mobileExecStepBtnHtml_(4, "Relato")}
        ${mobileExecStepBtnHtml_(5, "Assin.")}
        ${mobileExecStepBtnHtml_(6, "Fim")}
      </div>
      <div id="mExecPane1"></div>
      <div id="mExecPane2" style="display:none;"></div>
      <div id="mExecPane3" style="display:none;"></div>
      <div id="mExecPane4" style="display:none;"></div>
      <div id="mExecPane5" style="display:none;"></div>
      <div id="mExecPane6" style="display:none;"></div>
    </div>
  `;
  
  mobileExecStep_(1);
  mobileExecCarregarOS_();
}

function mobileExecStepBtnHtml_(n, label) {
  return `
    <button id="mExecStepBtn${n}" type="button" onclick="mobileExecStep_(${n})" style="border:1px solid var(--border);background:#fff;border-radius:8px;min-height:42px;padding:4px 2px;font-size:10px;font-weight:800;color:var(--muted);">
      <span style="display:block;font-size:13px;">${n}</span>
      <span>${label}</span>
    </button>
  `;
}

function mobileExecCarregarOS_() {
  var pane = document.getElementById("mExecPane1");
  if (pane) pane.innerHTML = mobileExecLoadingHtml_("Carregando OS...");
  
  google.script.run
    .withSuccessHandler(function(res) {
      if (!res || !res.success || !res.item) {
        if (pane) pane.innerHTML = mobileExecErroHtml_((res && res.message) || "OS não encontrada.");
        return;
      }
      var os = res.item;
      MOBILE_EXEC_STATE.os = os;
      var titulo = document.getElementById("mExecTitulo");
      var sub = document.getElementById("mExecSub");
      var badge = document.getElementById("mExecStatusBadge");
      
      if (titulo) titulo.textContent = "OS " + (os.NUMERO_OS || os.ID || "");
      if (sub) sub.textContent = [os.CLIENTE_NOME, os.UNIDADE_NOME].filter(Boolean).join(" | ") || "Execução em campo";
      if (badge) badge.textContent = os.STATUS || "OS";
      
      mobileExecRenderResumo_();
      mobileExecRenderFotos_();
      mobileExecRenderRelato_();
      mobileExecRenderAssinatura_();
      mobileExecRenderConcluir_();
      mobileExecCarregarChecklist_();
      mobileExecCarregarFotosEnviadas_();
      mobileExecCarregarAssinaturas_();
    })
    .withFailureHandler(function(err) {
      if (pane) pane.innerHTML = mobileExecErroHtml_("Erro ao carregar OS: " + ((err && err.message) || String(err)));
    })
    .osObter(SESSION, MOBILE_EXEC_STATE.osId);
}

function mobileExecStep_(n) {
  for (var i = 1; i <= 6; i++) {
    var pane = document.getElementById("mExecPane" + i);
    var btn = document.getElementById("mExecStepBtn" + i);
    if (pane) pane.style.display = i === n ? "" : "none";
    
    if (btn) {
      btn.style.background = i === n ? "var(--metro-green)" : "#fff";
      btn.style.color = i === n ? "#fff" : "var(--muted)";
      btn.style.borderColor = i === n ? "var(--metro-green)" : "var(--border)";
    }
  }
  
  var container = document.getElementById("mobilePaneContainer");
  if (container) container.scrollTop = 0;
  
  if (n === 5) setTimeout(function() {
    mobileExecInitCanvas_("mExecAssTecCanvas", "mExecAssTecHint");
    mobileExecInitCanvas_("mExecAssRespCanvas", "mExecAssRespHint");
  }, 40);
}

function mobileExecRenderResumo_() {
  var os = MOBILE_EXEC_STATE.os || {};
  var pane = document.getElementById("mExecPane1");
  if (!pane) return;
  
  var campo = function(label, val) {
    return val ? `
      <div style="padding:10px 0;border-bottom:1px solid #eef2f7;">
        <div style="font-size:11px;color:var(--muted);font-weight:800;text-transform:uppercase;">${label}</div>
        <div style="font-size:14px;font-weight:700;margin-top:3px;color:var(--text);">${escapeHtml_(val)}</div>
      </div>
    ` : '';
  };
  
  pane.innerHTML = `
    <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:14px;">
      <div style="font-size:15px;font-weight:800;margin-bottom:6px;">Resumo</div>
      ${campo("Cliente", os.CLIENTE_NOME || os.CLIENTE_ID)}
      ${campo("Unidade", os.UNIDADE_NOME || os.UNIDADE_ID)}
      ${campo("Endereço", os.UNIDADE_ENDERECO || os.ENDERECO)}
      ${campo("Equipamento", [os.EQUIPAMENTO_TAG, os.EQUIPAMENTO_TIPO, os.EQUIPAMENTO_MODELO].filter(Boolean).join(" - ") || os.EQUIPAMENTO_ID)}
      ${campo("Tipo", os.TIPO_OS)}
      ${campo("Prioridade", os.PRIORIDADE)}
      ${campo("Agendamento", formatarDataFront_(os.DATA_AGENDADA) || os.DATA_AGENDADA)}
      ${os.RELATO_CLIENTE ? `
        <div style="background:#f8fafc;border-radius:8px;padding:12px;margin-top:12px;">
