function mobileEquipUploadFotos_(equipId, onConcluido) {
  var slots   = ["plaqueta", "equipamento"];
  var tipos   = { plaqueta: "PLAQUETA", equipamento: "EQUIPAMENTO" };
  var idx     = 0;
  var erros   = [];

  function proximoSlot() {
    if (idx >= slots.length) {
      if (erros.length) mobileToast_("Equipamento salvo. Falha em " + erros.length + " foto(s).", "aviso");
      else              mobileToast_("Equipamento cadastrado com sucesso!", "ok");
      onConcluido();
      return;
    }
    
    var slot = slots[idx++];
    var foto = MOBILE_EQUIP_FOTOS[slot];
    if (!foto || !foto.base64) { proximoSlot(); return; }

    if (!equipId) { proximoSlot(); return; }

    google.script.run
      .withSuccessHandler(function(res) {
        if (!res || !res.success) erros.push(slot);
        proximoSlot();
      })
      .withFailureHandler(function(err) {
        erros.push(slot);
        proximoSlot();
      })
      .equipamentoFotoUploadBase64(SESSION, equipId, {
        BASE64_DATA: foto.base64,
        MIME_TYPE:   foto.mime,
        TIPO_FOTO:   tipos[slot],
        NOME_ARQUIVO: "equip_" + tipos[slot].toLowerCase() + "_" + (equipId || "novo") + "." + (foto.mime.includes("png") ? "png" : "jpg")
      });
  }

  proximoSlot();
}

