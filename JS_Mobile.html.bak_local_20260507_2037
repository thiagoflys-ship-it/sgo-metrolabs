function mobileSalvarCliente_() {
  var razao = (document.getElementById("mClienteRazaoSocial") || {}).value || "";
  razao = razao.trim();
  
  if (!razao) {
    mobileToast_("Razão Social é obrigatória.", "erro");
    return;
  }

  var btn = document.getElementById("mClienteSalvarBtn");
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right:8px;"></i>Salvando...'; }

  var payload = {
    RAZAO_SOCIAL:  razao,
    NOME_FANTASIA: ((document.getElementById("mClienteNomeFantasia") || {}).value || "").trim(),
    CNPJ:          ((document.getElementById("mClienteCnpj")         || {}).value || "").trim(),
