function mobileExecInputRespostaHtml_(p, valor) {
  var tipo = String(p.TIPO_RESPOSTA || "SIM_NAO").toUpperCase();
  
  if (tipo === "TEXTO_LONGO") return `<textarea class="m-exec-check-resp mobile-input" rows="3" style="width:100%;resize:vertical;">${escapeHtml_(valor)}</textarea>`;
  if (tipo === "TEXTO_CURTO") return `<input class="m-exec-check-resp mobile-input" type="text" value="${escapeHtml_(valor)}">`;
  if (tipo === "NUMERO" || tipo === "MEDICAO") return `<input class="m-exec-check-resp mobile-input" type="number" value="${escapeHtml_(valor)}">`;
  if (tipo === "DATA") return `<input class="m-exec-check-resp mobile-input" type="date" value="${escapeHtml_(valor)}">`;
  if (tipo === "HORA") return `<input class="m-exec-check-resp mobile-input" type="time" value="${escapeHtml_(valor)}">`;
  if (tipo === "FOTO") return `<input class="m-exec-check-resp" type="hidden" value="${escapeHtml_(valor)}">`;
  
  if (tipo === "MULTIPLA_ESCOLHA" || tipo === "SELECAO_UNICA") {
    var opcoes = String(p.OPCOES || "").split(";").filter(Boolean);
    return `
      <select class="m-exec-check-resp mobile-input mobile-select">
        <option value="">Selecione</option>
        ${opcoes.map(function(o) { return `<option value="${escapeHtml_(o)}"${o === valor ? " selected" : ""}>${escapeHtml_(o)}</option>`; }).join("")}
      </select>
    `;
  }
  
  var op = tipo === "CONFORME_NAO_CONFORME_NA" ? [["CONFORME","Conforme"],["NAO_CONFORME","Não conforme"],["NA","N/A"]] : [["SIM","Sim"],["NAO","Não"]];
  
  return `
    <div style="display:grid;grid-template-columns:repeat(${op.length},1fr);gap:7px;">
      ${op.map(function(o) {
        return `
          <label style="display:flex;align-items:center;justify-content:center;min-height:44px;border:1px solid var(--border);border-radius:9px;font-size:13px;font-weight:800;background:${o[0] === valor ? '#dcfce7' : '#fff'};">
            <input class="m-exec-check-resp" type="radio" name="m_resp_${escapeHtml_(p.ID)}" value="${o[0]}"${o[0] === valor ? " checked" : ""} style="margin-right:6px;">${o[1]}
          </label>
        `;
      }).join("")}
    </div>
  `;
}

function mobileExecSalvarChecklist_(silencioso, callback) {
  var modelo = MOBILE_EXEC_STATE.checklistModelo || {};
  
  if (!modelo.ID) {
    if (typeof callback === "function") callback({ success: true, skipped: true });
    return;
  }
  
  var respostas = [];
  document.querySelectorAll("#mExecPane2 [data-m-pergunta]").forEach(function(row) {
    var perguntaId = row.getAttribute("data-m-pergunta");
    var p = (MOBILE_EXEC_STATE.checklist || []).filter(function(i) { return i.ID === perguntaId; })[0] || {};
    var checked = row.querySelector(".m-exec-check-resp[type='radio']:checked");
    var respEl = checked || row.querySelector(".m-exec-check-resp");
    var respVal = (respEl && respEl.value) || "";
    var fotoVal = (row.querySelector(".m-exec-check-foto") || {}).value || "";
    if (String(p.TIPO_RESPOSTA || "").toUpperCase() === "FOTO" && !respVal) respVal = fotoVal;
    
    respostas.push({
      MISSAO_ID: MOBILE_EXEC_STATE.os && MOBILE_EXEC_STATE.os.MISSAO_ID,
      MODELO_ID: modelo.ID,
      PERGUNTA_ID: perguntaId,
      SECAO: p.SECAO,
      PERGUNTA: p.PERGUNTA,
      TIPO_RESPOSTA: p.TIPO_RESPOSTA,
      OBRIGATORIO: p.OBRIGATORIO,
      RESPOSTA: respVal,
      OBSERVACAO: (row.querySelector(".m-exec-check-obs") || {}).value || "",
      EVIDENCIA_LINK: fotoVal
    });
  });
  
  var motivoAlteracao = "";
  if (!mobileExecStatusPermiteEdicao_() && mobileExecPodeEditarExecucao_()) {
    motivoAlteracao = prompt("Informe o motivo para alterar questionário de OS já concluída:");
    if (!motivoAlteracao) {
      if (typeof callback === "function") callback({ success: false, message: "Motivo obrigatório." });
      return;
    }
  }
  
  google.script.run
    .withSuccessHandler(function(res) {
      if (res && res.success) {
        respostas.forEach(function(r) { MOBILE_EXEC_STATE.respostas[r.PERGUNTA_ID] = r; });
        if (!silencioso) mobileToast_("Checklist salvo.", "sucesso");
      } else if (!silencioso) {
        mobileToast_((res && res.message) || "Erro ao salvar checklist.", "erro");
      }
      if (typeof callback === "function") callback(res);
    })
    .withFailureHandler(function(err) {
      if (!silencioso) mobileToast_("Erro ao salvar checklist.", "erro");
      if (typeof callback === "function") callback({ success: false, message: err && err.message });
    })
    .checklistRespostasSalvar(SESSION, {
      OS_ID: MOBILE_EXEC_STATE.osId,
      MISSAO_ID: MOBILE_EXEC_STATE.os && MOBILE_EXEC_STATE.os.MISSAO_ID,
      MODELO_ID: modelo.ID,
      MOTIVO_ALTERACAO: motivoAlteracao,
      RESPOSTAS: respostas
    });
}

function mobileExecFotoQuestao_(input, perguntaId) {
  var file = input.files && input.files[0];
  if (!file) return;
  input.value = "";
  
  var statusEl = document.getElementById("mExecFotoStatus_" + perguntaId);
  if (statusEl) { statusEl.style.color = "var(--muted)"; statusEl.textContent = "Enviando foto..."; }
  
  var reader = new FileReader();
  reader.onload = function(e) {
    var base64 = e.target.result.replace(/^data:[^;]+;base64,/, "");
    
    google.script.run
      .withSuccessHandler(function(res) {
        if (!res || !res.success) {
          if (statusEl) { statusEl.style.color = "#dc2626"; statusEl.textContent = "Erro ao enviar foto"; }
          return;
        }
        var link = (res.item && res.item.LINK_DRIVE) || (res.item && res.item.FILE_ID) || "ok";
        var row = document.querySelector('#mExecPane2 [data-m-pergunta="' + perguntaId + '"]');
        
        if (row) {
          var fotoInput = row.querySelector(".m-exec-check-foto");
          var respInput = row.querySelector(".m-exec-check-resp");
          if (fotoInput) fotoInput.value = link;
          if (respInput && respInput.type === "hidden") respInput.value = link;
        }
        if (statusEl) { statusEl.style.color = "#059669"; statusEl.textContent = "Foto anexada"; }
      })
      .withFailureHandler(function(err) {
        if (statusEl) { statusEl.style.color = "#dc2626"; statusEl.textContent = "Erro: " + ((err && err.message) || "falha"); }
      })
      .osFotoUploadBase64(SESSION, MOBILE_EXEC_STATE.osId, {
        NOME_ARQUIVO: file.name,
        MIME_TYPE: file.type || "image/jpeg",
        BASE64_DATA: base64,
        TIPO_FOTO: "CHECKLIST",
        PERGUNTA_ID: perguntaId
      });
  };
  reader.readAsDataURL(file);
}

function mobileExecFotoGeral_(input) {
  var files = Array.prototype.slice.call(input.files || []);
  input.value = "";
  if (!files.length) return;
  
  var pendentes = files.length;
  var status = document.getElementById("mExecFotosStatus");
  if (status) status.textContent = "Enviando " + pendentes + " foto(s)...";
  
  files.forEach(function(file) {
    var reader = new FileReader();
    reader.onload = function(e) {
      var base64 = e.target.result.replace(/^data:[^;]+;base64,/, "");
      google.script.run
        .withSuccessHandler(function(res) {
          MOBILE_EXEC_STATE.fotosFila.push({ nome: file.name, status: res && res.success ? "ok" : "erro" });
          pendentes--;
          if (pendentes <= 0) {
            mobileExecCarregarFotosEnviadas_();
            if (status) status.textContent = "Foto geral enviada.";
          }
        })
        .withFailureHandler(function() {
          MOBILE_EXEC_STATE.fotosFila.push({ nome: file.name, status: "erro" });
          pendentes--;
          if (pendentes <= 0 && status) status.textContent = "Uma ou mais fotos falharam.";
        })
        .osFotoUploadBase64(SESSION, MOBILE_EXEC_STATE.osId, {
          NOME_ARQUIVO: file.name,
          MIME_TYPE: file.type || "image/jpeg",
          BASE64_DATA: base64,
          TIPO_FOTO: "Outro"
        });
    };
    reader.readAsDataURL(file);
  });
}

