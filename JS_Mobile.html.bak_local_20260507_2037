    })
    .clientesCriar(SESSION, payload);
}

function mobileBuscarCnpj_() {
  var cnpj = ((document.getElementById("mClienteCnpj") || {}).value || "").replace(/\D/g, "");
  
  if (cnpj.length !== 14) {
    mobileToast_("Digite um CNPJ valido (14 digitos).", "aviso");
    return;
  }

  var buscarBtn = document.querySelector('[onclick="mobileBuscarCnpj_()"]');
  if (buscarBtn) { buscarBtn.disabled = true; buscarBtn.textContent = "..."; }
  
  mobileToast_("Buscando na Receita Federal...", "ok");

  fetch("https://brasilapi.com.br/api/cnpj/v1/" + cnpj)
    .then(function(res) {
      if (!res.ok) throw new Error("CNPJ não encontrado (HTTP " + res.status + ")");
      return res.json();
    })
    .then(function(data) {
      var rsEl = document.getElementById("mClienteRazaoSocial");
      var nfEl = document.getElementById("mClienteNomeFantasia");
      var tfEl = document.getElementById("mClienteTelefone");
      if (rsEl) rsEl.value = data.razao_social || "";
      if (nfEl) nfEl.value = data.nome_fantasia || data.razao_social || "";
      if (tfEl) tfEl.value = data.ddd_telefone_1 || "";
      mobileToast_("Dados preenchidos pela Receita!", "ok");
    })
    .catch(function(err) {
      mobileToast_("CNPJ não encontrado na Receita. Preencha manualmente.", "aviso");
    })
    .finally(function() {
      if (buscarBtn) { buscarBtn.disabled = false; buscarBtn.textContent = "Buscar"; }
    });
}

function mobileBuscarCnpjUnidade_() {
  var cnpj = ((document.getElementById("mUnidadeCnpj") || {}).value || "").replace(/\D/g, "");
  
  if (cnpj.length !== 14) {
    mobileToast_("Digite um CNPJ valido (14 digitos).", "aviso");
    return;
  }

  var btn = document.getElementById("mUnidadeCnpjBtn");
  if (btn) { btn.disabled = true; btn.textContent = "..."; }
  mobileToast_("Buscando na Receita Federal...", "ok");

  fetch("https://brasilapi.com.br/api/cnpj/v1/" + cnpj)
    .then(function(res) {
      if (!res.ok) throw new Error("HTTP " + res.status);
      return res.json();
    })
    .then(function(data) {
      var nomeEl  = document.getElementById("mUnidadeNome");
      var endEl   = document.getElementById("mUnidadeEndereco");
      var cidEl   = document.getElementById("mUnidadeCidade");
