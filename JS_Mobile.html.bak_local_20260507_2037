  if (!texto.trim()) { mobileToast_("Preencha o relato antes de usar a IA.", "erro"); return; }
  
  if (painel) {
    painel.style.display = "block";
    painel.innerHTML = `
      <div style="font-size:11px;font-weight:800;color:#1e40af;margin-bottom:6px;">&#9889; Processando com IA...</div>
