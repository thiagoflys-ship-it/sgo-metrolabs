function mobileCapturaGPS_() {
  var btn    = document.getElementById("mUnidadeGpsBtn");
  var status = document.getElementById("mUnidadeGpsStatus");
  
  if (!navigator.geolocation) {
    if (status) { status.textContent = "GPS nao disponivel neste dispositivo."; status.className = "mobile-gps-status mobile-gps-erro"; }
    return;
  }

  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right:8px;"></i>Obtendo localização...'; }
  if (status) { status.textContent = ""; status.className = "mobile-gps-status"; }

  navigator.geolocation.getCurrentPosition(
    function(pos) {
      MOBILE_GPS_LAT = pos.coords.latitude;
      MOBILE_GPS_LNG = pos.coords.longitude;
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-circle-check" style="margin-right:8px;color:#16a34a;"></i>Localização capturada'; }
      if (status) {
        status.textContent = "Lat: " + MOBILE_GPS_LAT.toFixed(6) + " | Lng: " + MOBILE_GPS_LNG.toFixed(6);
        status.className = "mobile-gps-status mobile-gps-ok";
      }
    },
    function(err) {
      MOBILE_GPS_LAT = null;
      MOBILE_GPS_LNG = null;
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-location-dot" style="margin-right:8px;"></i>Usar localização atual'; }
      if (status) {
        var msg = err.code === 1 ? "Permissão negada." : err.code === 2 ? "Posição indisponível." : "Tempo esgotado.";
        status.textContent = msg;
        status.className = "mobile-gps-status mobile-gps-erro";
      }
    },
    { timeout: 15000, maximumAge: 60000, enableHighAccuracy: true }
  );
}

