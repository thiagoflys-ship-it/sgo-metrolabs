function mobileOSOnClienteChange_(clienteId) {
  var selUni = document.getElementById("mOSUnidadeId");
  var selEqp = document.getElementById("mOSEquipId");
  
  if (!selUni || !MOBILE_OS_OPCOES) return;

  if (!clienteId) {
    selUni.innerHTML = '<option value="">Selecione o cliente primeiro</option>';
    if (selEqp) selEqp.innerHTML = '<option value="">Selecione a unidade primeiro</option>';
    mobileOSLimparQuestionario_();
    return;
  }

  var unidades = (MOBILE_OS_OPCOES.unidades || []).filter(function(u) {
    return String(u.CLIENTE_ID) === String(clienteId);
  });
  
  selUni.innerHTML = unidades.length
    ? '<option value="">Selecione a unidade...</option>' + unidades.map(function(u) {
        return `<option value="${escapeHtml_(String(u.ID))}">${escapeHtml_(u.NOME || String(u.ID))}</option>`;
      }).join("")
    : '<option value="">Nenhuma unidade para este cliente</option>';
    
  if (selEqp) selEqp.innerHTML = '<option value="">Selecione a unidade primeiro</option>';

  var tipoInput = document.getElementById("mOSTipoEquip");
  if (tipoInput) tipoInput.value = "";
  mobileOSLimparQuestionario_();
}

function mobileOSOnUnidadeChange_(unidadeId) {
  var selEqp = document.getElementById("mOSEquipId");
  if (!selEqp || !MOBILE_OS_OPCOES) return;
  
  if (!unidadeId) {
    selEqp.innerHTML = '<option value="">Selecione a unidade primeiro</option>';
    var tipoInput = document.getElementById("mOSTipoEquip");
    if (tipoInput) tipoInput.value = "";
    mobileOSLimparQuestionario_();
    return;
  }

  var equips = (MOBILE_OS_OPCOES.equipamentos || []).filter(function(e) {
    return String(e.UNIDADE_ID) === String(unidadeId);
  });
  
  selEqp.innerHTML = equips.length
    ? '<option value="">Selecione o equipamento...</option>' + equips.map(function(e) {
        var label = e.LABEL || [e.TAG, e.TIPO, e.MODELO].filter(Boolean).join(" - ") || String(e.ID);
        return `<option value="${escapeHtml_(String(e.ID))}" data-tipo="${escapeHtml_(e.TIPO || "")}">${escapeHtml_(label)}</option>`;
      }).join("")
    : '<option value="">Nenhum equipamento para esta unidade</option>';
    
  var tipoInput = document.getElementById("mOSTipoEquip");
  if (tipoInput) tipoInput.value = "";
  mobileOSLimparQuestionario_();
}

function mobileOSOnEquipChange_(equipId) {
  var tipoInput = document.getElementById("mOSTipoEquip");
  
  if (!equipId || !MOBILE_OS_OPCOES) {
    if (tipoInput) tipoInput.value = "";
    mobileOSLimparQuestionario_();
    return;
  }

  var equip = (MOBILE_OS_OPCOES.equipamentos || []).find(function(e) {
    return String(e.ID) === String(equipId);
  });
  
  var tipo = equip ? (equip.TIPO || "") : "";
  if (tipoInput) tipoInput.value = tipo;

  mobileOSCheckQuestionario_();
}

function mobileOSOnTipoOSChange_(tipoOS) {
  mobileOSCheckQuestionario_();
}

function mobileOSCheckQuestionario_() {
  var tipoOSEl    = document.getElementById("mOSTipoOS");
  var tipoEquipEl = document.getElementById("mOSTipoEquip");
  
  if (!tipoOSEl || !tipoEquipEl) return;

  var tipoOS    = (tipoOSEl.value    || "").trim();
  var tipoEquip = (tipoEquipEl.value || "").trim();

  if (!tipoOS || !tipoEquip) { mobileOSLimparQuestionario_(); return; }

  var card = document.getElementById("mOSQuestionarioCard");
  if (card) {
    card.style.display = "";
    card.innerHTML = `
      <div style="padding:10px 14px;border-radius:10px;background:#f0fdf4;border:1px solid #86efac;">
        <i class="fas fa-spinner fa-spin" style="color:#16a34a;margin-right:8px;"></i>
        <span style="font-size:13px;color:#15803d;">Buscando questionário sugerido...</span>
      </div>
    `;
  }

  MOBILE_OS_QUESTIONARIO = null;

  google.script.run
    .withSuccessHandler(function(res) {
      if (res && res.success && res.item && res.item.ID) {
        var m = res.item;
        MOBILE_OS_QUESTIONARIO = {
          id:    m.ID   || "",
          nome:  m.NOME || "",
          total: m.TOTAL_PERGUNTAS || m.TOTAL_ITENS || (m.perguntas ? m.perguntas.length : 0) || (m.itens ? m.itens.length : 0) || ""
        };
        mobileOSMostrarCardQuestionario_(true);
      } else {
        MOBILE_OS_QUESTIONARIO = null;
        mobileOSMostrarCardQuestionario_(false);
      }
    })
    .withFailureHandler(function(err) {
      MOBILE_OS_QUESTIONARIO = null;
      mobileOSMostrarCardQuestionario_(false);
    })
    .checklistModeloPorTipoOSTipoEquipamento(SESSION, tipoOS, tipoEquip);
}

function mobileOSMostrarCardQuestionario_(encontrado) {
  var card = document.getElementById("mOSQuestionarioCard");
  if (!card) return;
  card.style.display = "";
  
  if (encontrado && MOBILE_OS_QUESTIONARIO) {
    var q = MOBILE_OS_QUESTIONARIO;
    card.innerHTML = `
      <div style="padding:12px 16px;border-radius:10px;background:#f0fdf4;border:1px solid #86efac;">
        <div style="font-weight:700;font-size:13px;color:#166534;margin-bottom:4px;">
          <i class="fas fa-circle-check" style="margin-right:6px;"></i>Questionário sugerido: ${escapeHtml_(q.nome)}
        </div>
        ${q.total ? `<div style="font-size:12px;color:#15803d;">Perguntas: ${escapeHtml_(String(q.total))}</div>` : ''}
      </div>
    `;
  } else {
    card.innerHTML = `
      <div style="padding:12px 16px;border-radius:10px;background:#fefce8;border:1px solid #fde047;">
        <div style="font-weight:700;font-size:13px;color:#854d0e;margin-bottom:4px;">
          <i class="fas fa-triangle-exclamation" style="margin-right:6px;"></i>Nenhum questionário configurado
        </div>
        <div style="font-size:12px;color:#713f12;">Nenhum questionário para este tipo de OS / equipamento. A OS pode ser criada mesmo assim.</div>
      </div>
    `;
  }
}

function mobileOSLimparQuestionario_() {
  MOBILE_OS_QUESTIONARIO = null;
  var card = document.getElementById("mOSQuestionarioCard");
  if (card) card.style.display = "none";
}

function mobileOSAplicarPrefill_() {
  var pf = MOBILE_OS_PREFILL;
  if (!pf) return;

  var selCliente = document.getElementById("mOSClienteId");
  if (selCliente && pf.clienteId) {
    selCliente.value = String(pf.clienteId);
    mobileOSOnClienteChange_(String(pf.clienteId));
  }

  setTimeout(function() {
    var selUnidade = document.getElementById("mOSUnidadeId");
    if (selUnidade && pf.unidadeId) {
      selUnidade.value = String(pf.unidadeId);
      mobileOSOnUnidadeChange_(String(pf.unidadeId));
    }
    setTimeout(function() {
      var selEquip = document.getElementById("mOSEquipId");
      if (selEquip && pf.equipamentoId) {
        selEquip.value = String(pf.equipamentoId);
        mobileOSOnEquipChange_(String(pf.equipamentoId));
      }
      MOBILE_OS_PREFILL = null;
    }, 60);
  }, 60);
}

function mobileSalvarNovaOS_() {
  var clienteId  = ((document.getElementById("mOSClienteId")    || {}).value || "").trim();
  var unidadeId  = ((document.getElementById("mOSUnidadeId")    || {}).value || "").trim();
  var equipId    = ((document.getElementById("mOSEquipId")      || {}).value || "").trim();
  var tipoOS     = ((document.getElementById("mOSTipoOS")       || {}).value || "").trim();
  var prioridade = ((document.getElementById("mOSPrioridade")   || {}).value || "").trim();
  var relato     = ((document.getElementById("mOSRelatoCliente") || {}).value || "").trim();

  if (!clienteId)  { mobileToast_("Selecione o cliente.", "erro"); return; }
  if (!unidadeId)  { mobileToast_("Selecione a unidade.", "erro"); return; }
  if (!equipId)    { mobileToast_("Selecione o equipamento.", "erro"); return; }
  if (!tipoOS)     { mobileToast_("Selecione o tipo de OS.", "erro"); return; }
  if (!prioridade) { mobileToast_("Selecione a prioridade.", "erro"); return; }
  if (!relato)     { mobileToast_("Informe o relato do cliente.", "erro"); return; }

  var btn = document.getElementById("mOSSalvarBtn");
  if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right:8px;"></i>Criando OS...'; }

  var orientacao = ((document.getElementById("mOSOrientacao")   || {}).value || "").trim();
  var tecnicoId  = ((document.getElementById("mOSTecnicoId")    || {}).value || "").trim();
  var dataAgend  = ((document.getElementById("mOSDataAgendada") || {}).value || "").trim();

  var payload = {
    CLIENTE_ID:         clienteId,
    UNIDADE_ID:         unidadeId,
    EQUIPAMENTO_ID:     equipId,
    TIPO_OS:            tipoOS,
    PRIORIDADE:         prioridade,
    RELATO_CLIENTE:     relato,
    ORIENTACAO_TECNICA: orientacao
  };
  
  if (tecnicoId) payload.TECNICO_ID    = tecnicoId;
  if (dataAgend) payload.DATA_AGENDADA = dataAgend;
  
  if (MOBILE_OS_QUESTIONARIO && MOBILE_OS_QUESTIONARIO.id) {
    payload.QUESTIONARIO_MODELO_ID = MOBILE_OS_QUESTIONARIO.id;
  }

  google.script.run
    .withSuccessHandler(function(res) {
      if (!res || !res.success) {
        mobileToast_((res && res.message) || "Falha ao criar OS.", "erro");
        if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-save" style="margin-right:8px;"></i>Criar OS'; }
        return;
      }
      var osId    = (res.item && (res.item.ID || res.item.id)) || res.id || "";
      var numOS   = (res.item && res.item.NUMERO_OS) || "";
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-save" style="margin-right:8px;"></i>Criar OS'; }
      mobileOSDialogPosCriar_(osId, numOS);
    })
    .withFailureHandler(function(err) {
      mobileToast_("Erro ao criar OS: " + (err.message || String(err)), "erro");
      if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fas fa-save" style="margin-right:8px;"></i>Criar OS'; }
    })
    .osCriar(SESSION, payload);
}

