  var reader = new FileReader();
  reader.onload = function(e) {
    var dataUrl  = e.target.result;
    var sepIdx   = dataUrl.indexOf(",");
    var base64   = dataUrl.substring(sepIdx + 1);
    
    MOBILE_EQUIP_FOTOS[slot] = { base64: base64, mime: file.type || "image/jpeg", nome: file.name };
    
    var thumbWrap = document.getElementById(slot === "plaqueta" ? "mEquipThumbPlaqueta" : "mEquipThumbEquip");
    var thumbImg  = document.getElementById(slot === "plaqueta" ? "mEquipImgPlaqueta"   : "mEquipImgEquip");
    var btn       = document.getElementById(slot === "plaqueta" ? "mEquipBtnPlaqueta"   : "mEquipBtnEquip");
    
    if (thumbImg)  thumbImg.src      = dataUrl;
    if (thumbWrap) thumbWrap.style.display = "";
    if (btn)       btn.style.display = "none";
  };
  reader.readAsDataURL(file);
}

