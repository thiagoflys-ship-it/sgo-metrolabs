/* ---- Toast ---- */

function mobileToast_(msg, tipo) {
  var existing = document.getElementById("mobileToastEl");
  if (existing) existing.remove();

  var el = document.createElement("div");
  el.id = "mobileToastEl";
  el.className = "mobile-toast mobile-toast-" + (tipo || "ok");
  el.textContent = msg;

  var shell = document.getElementById("mobileCampoShell");
  (shell || document.body).appendChild(el);

  setTimeout(function() { el.classList.add("mobile-toast-show"); }, 10);
  setTimeout(function() {
    el.classList.remove("mobile-toast-show");
    setTimeout(function() { el.remove(); }, 350);
  }, 3000);
}

